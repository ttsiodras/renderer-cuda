# Simple Makefile for ROCm/HIP build
# Requires: ROCm/HIP toolkit installed

# HIP compiler (usually hipcc)
HIPCC = hipcc

# HIP installation path (adjust if needed)
HIP_PATH ?= /opt/rocm

# Compiler flags
CXXFLAGS = -O2 -g -std=c++11 -I$(HIP_PATH)/include -I. -I /usr/include/SDL -I /opt/rocm/include
LDFLAGS = -L$(HIP_PATH)/lib -lGL -lGLU -lglut -lSDL -lhipblas -lamdhip64 -lGLEW ../lib3ds-1.3.0/lib3ds/.libs/lib3ds.so

# Source files
SRCS = main_rocm.cpp hiprenderer.hip.cpp \
    Algebra.cpp BVH.cpp Camera.cpp Keyboard.cpp \
    Loader.cpp Utility.cpp

# Object files
CPP_SRCS = main_rocm.cpp Algebra.cpp BVH.cpp Camera.cpp Keyboard.cpp Loader.cpp Utility.cpp
HIP_SRCS = hiprenderer.hip.cpp
OBJS = $(CPP_SRCS:.cpp=.o) $(HIP_SRCS:.hip.cpp=.o)

# Target
TARGET = hipRenderer

# Default target
all: $(TARGET)

# Link
$(TARGET): $(OBJS)
	$(CXX) $(LDFLAGS) -o $@ $^

# Compile C++ files
%.o: %.cpp
	$(HIPCC) $(CXXFLAGS) -c -o $@ $<

# Compile HIP files
%.o: %.hip.cpp
	$(HIPCC) $(CXXFLAGS) -c -o $@ $<

# Clean
clean:
	rm -f $(OBJS) $(TARGET)

# Install (optional)
install: $(TARGET)
	cp $(TARGET) /usr/local/bin/

.PHONY: all clean install
